# Copy this file to .env and fill in your Telegram details.
# Do not share the bot token publicly.

# Create with @BotFather.
TELEGRAM_BOT_TOKEN=1234567890:replace_with_your_bot_token

# Public channel username, for example @your_public_calls_channel.
# Add the bot as channel admin with permission to post messages.
TELEGRAM_CHAT_ID=@your_public_channel

# TradingView webhook listener settings.
# If TRADINGVIEW_WEBHOOK_SECRET is set, the Pine script should send the same value.
TRADINGVIEW_WEBHOOK_HOST=0.0.0.0
TRADINGVIEW_WEBHOOK_PORT=8787
TRADINGVIEW_WEBHOOK_PATH=/webhook/tradingview
TRADINGVIEW_WEBHOOK_SECRET=

# Optional manual CA list to scan in addition to DexScreener feeds.
WATCHLIST_TOKENS=

# Alert cadence and duplicate control.
INTERVAL_MINUTES=5
MAX_CALLS_PER_RUN=3
COOLDOWN_HOURS=6
CALL_EXPIRY_MINUTES=30

# Filters. Tighten these if the channel gets noisy.
MIN_SCORE=85
MIN_LIQ_USD=30000
MIN_VOL_1H_USD=7500
MIN_VOL_24H_USD=75000
MIN_TX_1H=80
MIN_BUY_SELL_RATIO=0.95
MIN_M5_PCT=-3
MAX_M5_PCT=10
MIN_H1_PCT=0
MAX_H1_PCT=25
MIN_H6_PCT=-35
